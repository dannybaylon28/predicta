VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# URL publica de la app (invitaciones, Open Graph, Stripe redirects)
VITE_APP_URL=https://predictaclub.com
APP_URL=https://predictaclub.com

# Solo para pruebas locales con public/data/worldcup-games.json (npm run dev)
VITE_USE_LOCAL_MATCHES=false

# Stripe (solo servidor / Vercel — NO usar prefijo VITE_)
# Pruebas: sk_test_... + webhook en modo prueba
# Produccion: sk_live_... + webhook en modo activo (solo target production en Vercel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin para webhooks de Stripe (JSON en una linea)
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
