{
  "name": "predicta",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "sync:matches": "mkdir -p public/data && curl -fsSL https://worldcup26.ir/get/games -o public/data/worldcup-games.json && curl -fsSL https://worldcup26.ir/get/stadiums -o public/data/worldcup-stadiums.json",
    "test": "vitest run",
    "generate:icons": "node scripts/generate-icons.mjs",
    "vercel:env": "node scripts/push-vercel-env.mjs",
    "vercel:env:server": "node scripts/push-vercel-server-env.mjs"
  },
  "dependencies": {
    "@vercel/node": "^5.8.14",
    "@vitejs/plugin-react": "^4.3.4",
    "firebase": "^11.10.0",
    "firebase-admin": "^14.0.0",
    "jose": "^5.10.0",
    "lucide-react": "^0.468.0",
    "micro": "^10.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^6.30.4",
    "stripe": "^22.2.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vercel": "^54.9.1",
    "vitest": "^3.2.4"
  }
}
